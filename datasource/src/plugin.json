{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "datasource",
  "name": "Ingero GPU",
  "id": "ingero-gpu-datasource",
  "metrics": true,
  "backend": true,
  "executable": "gpx_ingero_gpu",
  "info": {
    "description": "Datasource for NVIDIA GPU telemetry from the Ingero Echo API. Run SQL against the GPU event store, call MCP tools as panel data, and stream detected anomalies into Grafana panels and alerts.",
    "keywords": ["nvidia", "gpu", "cuda", "nccl", "monitoring", "observability", "sql", "mcp", "ingero", "echo"],
    "author": {
      "name": "Ingero",
      "url": "https://github.com/ingero-io"
    },
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "links": [
      {
        "name": "GitHub",
        "url": "https://github.com/ingero-io/ingero-grafana-app"
      }
    ],
    "screenshots": [],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "dependencies": {
    "grafanaDependency": ">=12.3.0",
    "plugins": []
  }
}
