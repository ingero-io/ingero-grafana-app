    "gpu",
    "cuda",
    "memcpy",
    "nccl",
    "ebpf",
    "pytorch",
    "dataloader",
    "single-node",
    "ingero"
  ],
  "templating": {
    "list": [
      {
        "name": "ingero_source",
        "type": "datasource",
        "label": "Ingero",
        "description": "Pick which Ingero datasource (Echo endpoint) to query.",
        "query": "ingero-gpu-datasource",
        "current": {
          "selected": false,
          "text": "default",
          "value": "default"
        },
        "options": [],
        "regex": "",
        "refresh": 1,
        "skipUrlSync": false,
        "includeAll": false,
        "multi": false,
        "hide": 0
      }
    ]
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "browser",
  "title": "GPU Data Movement: CUDA memcpy + NCCL collectives (single host)",
  "uid": "ingero-single-node-memcpy-nccl",
  "version": 1,
  "weekStart": ""
}
