{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "heatmap",
      "name": "Heatmap",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Single-host CUDA memcpy + NCCL data-movement dashboard. Per-direction memcpy throughput + p50/p95/p99 (from per-event histogram), local NCCL collective rates by op_type, libnccl version roster. Answer: is data movement my bottleneck on this box? eBPF uprobes on libcudart and libnccl.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Total memcpy throughput",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(gpu_memcpy_bytes_total[1m]))",
          "legendFormat": "B/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Memcpy p50 (all directions)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(gpu_memcpy_duration_ms_bucket[1m])))",
          "legendFormat": "p50 ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2
        }
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Memcpy p95",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gpu_memcpy_duration_ms_bucket[1m])))",
          "legendFormat": "p95 ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2
        }
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Memcpy p99",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(gpu_memcpy_duration_ms_bucket[1m])))",
          "legendFormat": "p99 ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "timeseries",
      "title": "Memcpy bandwidth per direction",
      "description": "h2d = host->device (DataLoader pushing batches). d2h = device->host (CPU-side metric collection). d2d = device->device (peer copy or in-GPU shuffle). 'unknown' from CUDAMemcpy2D variants where the kind arg is the 7th parameter and not portably readable from BPF.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (direction) (rate(gpu_memcpy_bytes_total[1m]))",
          "legendFormat": "{{direction}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Memcpy duration percentiles per direction",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (direction, le) (rate(gpu_memcpy_duration_ms_bucket[1m])))",
          "legendFormat": "p95 / {{direction}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "heatmap",
      "title": "Memcpy duration distribution (all directions)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(gpu_memcpy_duration_ms_bucket[1m]))",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": false
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 8
      }
    },
    {
      "type": "stat",
      "title": "Local NCCL processes",
      "description": "From gpu_nccl_processes_total. The discovery scanner finds libnccl-loaded PIDs and reports the count.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "gpu_nccl_processes_total",
          "legendFormat": "PIDs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "NCCL collective rate",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(gpu_nccl_collective_count[1m]))",
          "legendFormat": "events/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1
        }
      },
      "gridPos": {
        "x": 6,
        "y": 21,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Total NCCL bytes (15m)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(increase(gpu_nccl_collective_bytes_total[15m]))",
          "legendFormat": "bytes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 21,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Distinct libnccl versions",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "count(group by (libnccl_version) (gpu_nccl_process_loaded))",
          "legendFormat": "versions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "x": 18,
        "y": 21,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "timeseries",
      "title": "NCCL collective rate by op_type",
      "description": "Locally-fired collectives. ncclAllReduce = data-parallel sync; ncclAllGather/ReduceScatter = ZeRO/FSDP shards; ncclBcast = shape-sync; ncclSend/Recv = pipeline parallelism.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (op_type) (rate(gpu_nccl_collective_count[1m]))",
          "legendFormat": "{{op_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "NCCL bandwidth by op_type",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (op_type) (rate(gpu_nccl_collective_bytes_total[1m]))",
          "legendFormat": "{{op_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 25,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "table",
      "title": "Local libnccl-loaded processes",
      "description": "From gpu_nccl_process_loaded. Each row = one PID the discovery scanner found with libnccl in its memory map.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "gpu_nccl_process_loaded",
          "legendFormat": "{{pid}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "Value": true
            }
          }
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 24,
        "h": 6
      }
    }
  ],
  "refresh": "10s",
  "revision": 1,
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
