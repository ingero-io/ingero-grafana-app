{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Per-node NVIDIA GPU drill-down dashboard. Pick a node from the variable; everything filters to that host. Per-GPU memory + throttle, NCCL collective rates, memcpy duration percentiles, IOCTL event rates per cmd, kernel launch threads-per-block percentiles. Use after cluster overview surfaces a candidate.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "GPUs on $node",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "count(group by (gpu_uuid) (gpu_memory_total_bytes{instance=\"$node\"}))",
          "legendFormat": "GPUs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Memory used %",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(gpu_memory_used_bytes{instance=\"$node\"}) / sum(gpu_memory_total_bytes{instance=\"$node\"})",
          "legendFormat": "used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "NCCL processes",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "gpu_nccl_processes_total{instance=\"$node\"}",
          "legendFormat": "PIDs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Memcpy throughput",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(gpu_memcpy_bytes_total{instance=\"$node\"}[5m]))",
          "legendFormat": "B/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Throttle events / 5m",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(increase(gpu_throttle_power_event_total{instance=\"$node\"}[5m]) + increase(gpu_throttle_thermal_event_total{instance=\"$node\"}[5m]) + increase(gpu_throttle_sw_event_total{instance=\"$node\"}[5m]) + increase(gpu_throttle_hw_event_total{instance=\"$node\"}[5m]))",
          "legendFormat": "events"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Kernel launches / sec",
      "description": "M. Sum of gpu_kernel_launch_count rate. Empty when --enable-experimental-kprobes is off OR libcuda not discoverable.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(gpu_kernel_launch_count{instance=\"$node\"}[5m]))",
          "legendFormat": "launches/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1
        }
      },
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      }
    },
    {
      "type": "timeseries",
      "title": "Memory used per GPU on $node",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "gpu_memory_used_bytes{instance=\"$node\"}",
          "legendFormat": "used / {{gpu_uuid}}"
        },
        {
          "expr": "gpu_memory_total_bytes{instance=\"$node\"}",
          "legendFormat": "total / {{gpu_uuid}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Throttle bitmask per GPU on $node",
      "description": "Per-bucket gauge: 1=active. Concurrent active buckets = compound throttle (e.g. power + thermal during sustained load).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "gpu_throttle_power_active{instance=\"$node\"}",
          "legendFormat": "power / {{gpu_uuid}}"
        },
        {
          "expr": "gpu_throttle_thermal_active{instance=\"$node\"}",
          "legendFormat": "thermal / {{gpu_uuid}}"
        },
        {
          "expr": "gpu_throttle_sw_active{instance=\"$node\"}",
          "legendFormat": "sw / {{gpu_uuid}}"
        },
        {
          "expr": "gpu_throttle_hw_active{instance=\"$node\"}",
          "legendFormat": "hw / {{gpu_uuid}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "NCCL collectives on $node",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(gpu_nccl_collective_count{instance=\"$node\"}[5m])",
          "legendFormat": "{{op_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Memcpy duration percentiles on $node",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (direction, le) (rate(gpu_memcpy_duration_ms_bucket{instance=\"$node\"}[5m])))",
          "legendFormat": "p50 {{direction}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (direction, le) (rate(gpu_memcpy_duration_ms_bucket{instance=\"$node\"}[5m])))",
          "legendFormat": "p95 {{direction}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Memfrag IOCTL events on $node (top 5 cmd)",
      "description": "experimental. Empty when the agent on $node is not running with --enable-experimental-kprobes.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "topk(5, sum by (cmd) (rate(gpu_memfrag_ioctl_event_total{instance=\"$node\"}[5m])))",
          "legendFormat": "cmd={{cmd}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Kernel launch rate per PID on $node",
      "description": "experimental. Per-PID rate from the cuLaunchKernel uprobe.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(gpu_kernel_launch_count{instance=\"$node\"}[5m])",
          "legendFormat": "pid={{pid}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Kernel threads-per-block percentiles on $node",
      "description": "M. p50 / p95 of (BlockX * BlockY) per launch. Outliers near the high end (e.g. >512) often saturate registers; near the low end (e.g. <64) under-use SMs.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(gpu_kernel_launch_threads_per_block_bucket{instance=\"$node\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gpu_kernel_launch_threads_per_block_bucket{instance=\"$node\"}[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "table",
      "title": "Process roster on $node",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "gpu_memory_process_allocated_bytes{instance=\"$node\"}",
          "legendFormat": "{{pid}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "gridPos": {
        "x": 12,
        "y": 28,
        "w": 12,
        "h": 8
      }
    }
  ],
  "refresh": "30s",
  "revision": 1,
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "nvidia",
    "gpu",
    "cuda",
    "nccl",
    "memcpy",
    "throttle",
    "drilldown",
    "multi-node",
    "ebpf",
    "ingero"
  ],
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(gpu_memory_total_bytes, instance)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "label": "Node"
      },
      {
        "name": "ingero_source",
        "type": "datasource",
        "label": "Ingero",
        "description": "Pick which Ingero datasource (Echo endpoint) to query.",
        "query": "ingero-gpu-datasource",
        "current": {
          "selected": false,
          "text": "default",
          "value": "default"
        },
        "options": [],
        "regex": "",
        "refresh": 1,
        "skipUrlSync": false,
        "includeAll": false,
        "multi": false,
        "hide": 0
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Per-Node GPU Drill-Down: CUDA, NCCL, memcpy, throttle, kernel launch",
  "uid": "ingero-cluster-per-node",
  "version": 1,
  "weekStart": ""
}
