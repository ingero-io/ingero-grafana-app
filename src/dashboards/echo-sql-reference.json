        "query": "ingero-gpu-datasource",
        "current": {
          "selected": false,
          "text": "default",
          "value": "default"
        },
        "options": [],
        "regex": "",
        "refresh": 1,
        "skipUrlSync": false,
        "includeAll": false,
        "multi": false,
        "hide": 0
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "Ingero Echo SQL (reference)",
  "uid": "ingero-echo-sql-reference",
  "version": 1,
  "weekStart": ""
